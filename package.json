{
  "name": "canvas-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Canvas LMS API — PUC Minas student workflows",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.5",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "axios": "^1.7.9",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "node-html-parser": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "turndown": "^7.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^2.1.8",
    "msw": "^2.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
